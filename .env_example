MONGO_URI = example

# Google Safe Browsing API (URL validation for comments)
# Get a key at: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY = your_api_key_here

# Email (contact form — Nodemailer via Outlook SMTP)
EMAIL_USER = your_hotmail@hotmail.com
EMAIL_PASS = your_app_password_here
# Optional: send TO a different address than EMAIL_USER (defaults to EMAIL_USER if omitted)
EMAIL_TO   = maria_ingerslev@hotmail.com
